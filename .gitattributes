# Large binary test fixtures (camera RAW frames and clip audio) are stored via
# Git LFS so the repository stays small. XMP/text sidecars stay as normal text.
*.DNG filter=lfs diff=lfs merge=lfs -text
*.dng filter=lfs diff=lfs merge=lfs -text
*.WAV filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text

# Binary design sources (Illustrator, Photoshop, Sketch) are opaque blobs — store
# them in LFS. SVG logos stay normal text: they diff cleanly and are tiny.
*.ai filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
*.sketch filter=lfs diff=lfs merge=lfs -text
