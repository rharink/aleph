# Large binary test fixtures (camera RAW frames and clip audio) are stored via
# Git LFS so the repository stays small. XMP/text sidecars stay as normal text.
*.DNG filter=lfs diff=lfs merge=lfs -text
*.dng filter=lfs diff=lfs merge=lfs -text
*.WAV filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
